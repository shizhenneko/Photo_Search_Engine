# Country 版本
#
# 说明：
# - 除 embedding 和 text rerank 之外，全部使用 Kimi。
# - LLM_* 作为统一入口；各子服务默认继承它。
# - embedding 与 text rerank 保留独立的 Qwen / Tumuer 配置。

PHOTO_DIR=C:/Users/86159/Desktop/test_photos

DATA_DIR=./data
RUNTIME_DATA_DIR=./data

# 通用 LLM（Kimi）
LLM_API_KEY=sk-your-kimi-key
LLM_BASE_URL=https://api.moonshot.cn/v1

# 兼容旧变量
SU8_API_KEY=${LLM_API_KEY}
SU8_BASE_URL=${LLM_BASE_URL}

# Vision / 结构化分析
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=kimi-latest
VISION_REASONING_EFFORT=high
VISION_ENHANCED_REASONING_EFFORT=medium
VISION_BASE_MAX_TOKENS=900
VISION_ENHANCED_MAX_TOKENS=640
VISION_REPAIR_MAX_TOKENS=640
STRUCTURED_ANALYSIS_ENABLED=true
ENHANCED_ANALYSIS_ENABLED=true
TAG_MIN_CONFIDENCE=0.65
IDENTITY_TEXT_MIN_CONFIDENCE=0.70
IDENTITY_VISUAL_MIN_CONFIDENCE=0.92

# 时间解析：走 Kimi
TIME_PARSE_API_KEY=
TIME_PARSE_BASE_URL=
TIME_PARSE_MODEL=kimi-k2
TIME_PARSE_REASONING_EFFORT=medium
TIME_PARSE_STRATEGY=local_first

# Query Formatter：走 Kimi
QUERY_FORMAT_ENABLED=true
QUERY_FORMAT_API_KEY=
QUERY_FORMAT_BASE_URL=
QUERY_FORMAT_MODEL=kimi-k2
QUERY_FORMAT_REASONING_EFFORT=medium
QUERY_EXPANSION_ENABLED=true
QUERY_MULTI_ROUND_ENABLED=true
QUERY_REFLECTION_ENABLED=true
QUERY_MAX_EXPANSION_ROUNDS=3
QUERY_MAX_REFLECTION_ROUNDS=2
QUERY_EXPANSION_MAX_ALTERNATIVES=3
QUERY_DYNAMIC_THRESHOLD_FLOOR=0.10
QUERY_STRICT_FLOOR_MIN=0.36
QUERY_BROAD_FLOOR_MIN=0.24
QUERY_CACHE_ENABLED=true
QUERY_CACHE_SIZE=2000

# Embedding：独立保留
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_BASE_URL=https://router.tumuer.me/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIMENSION=4096
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_CACHE_SIZE=5000
DISK_CACHE_ENABLED=false

# 文本 rerank：独立保留
TEXT_RERANK_API_KEY=sk-your-rerank-key
TEXT_RERANK_BASE_URL=https://router.tumuer.me/v1
TEXT_RERANK_MODEL=Qwen/Qwen3-Reranker-8B
TEXT_RERANK_BACKEND=api
TEXT_RERANK_TIMEOUT=45

# 混合检索
VECTOR_METRIC=cosine
VECTOR_INDEX_TYPE=hnsw
HNSW_M=48
HNSW_EF_CONSTRUCTION=320
HNSW_EF_SEARCH=192
VECTOR_WEIGHT=0.78
KEYWORD_WEIGHT=0.22

# Elasticsearch
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=photo_keywords
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Visual rerank：走 Kimi
VISUAL_RERANK_ENABLED=true
VISUAL_RERANK_API_KEY=
VISUAL_RERANK_BASE_URL=
VISUAL_RERANK_MODEL=kimi-latest
VISUAL_RERANK_REASONING_EFFORT=high
VISUAL_RERANK_TIMEOUT=90
RERANK_IMAGE_MAX_SIZE=768
RERANK_IMAGE_QUALITY=85
RERANK_IMAGE_FORMAT=WEBP
RERANK_MAX_IMAGES=18

# 服务与索引
SERVER_HOST=127.0.0.1
SERVER_PORT=10001
TOP_K=12
DEFAULT_SEARCH_MODE=high_recall
SEARCH_VALIDATE_FILE_EXISTS=true
BATCH_SIZE=8
MAX_RETRIES=3
TIMEOUT=60
INDEX_PATH=./data/photo_search.index
METADATA_PATH=./data/metadata.json
SECRET_KEY=dev-secret-key

# 图片编码
USE_BASE64=true
IMAGE_MAX_SIZE=1280
IMAGE_QUALITY=90
IMAGE_FORMAT=WEBP
