# Online 版本：使用 OpenAI 兼容在线 GPT 模型

# 照片目录（绝对路径，支持 Windows 路径或 WSL 路径）
PHOTO_DIR=C:/Users/86159/Desktop/test_photos

# 数据目录
DATA_DIR=./data
RUNTIME_DATA_DIR=./data

# 通用 LLM（Vision + 时间解析 + QueryFormatter + 视觉 rerank 默认复用）
LLM_API_KEY=sk-your-online-key
LLM_BASE_URL=https://www.su8.codes/codex/v1

# 兼容旧变量名，保留给现有部署使用
SU8_API_KEY=${LLM_API_KEY}
SU8_BASE_URL=${LLM_BASE_URL}

# Vision
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=gpt-5.4
VISION_REASONING_EFFORT=medium
STRUCTURED_ANALYSIS_ENABLED=true
ENHANCED_ANALYSIS_ENABLED=true
TAG_MIN_CONFIDENCE=0.65
IDENTITY_TEXT_MIN_CONFIDENCE=0.70
IDENTITY_VISUAL_MIN_CONFIDENCE=0.92

# 时间解析
TIME_PARSE_MODEL=gpt-5.1
TIME_PARSE_REASONING_EFFORT=low
TIME_PARSE_STRATEGY=local_first

# QueryFormatter
QUERY_FORMAT_ENABLED=true
QUERY_FORMAT_API_KEY=
QUERY_FORMAT_BASE_URL=
QUERY_FORMAT_MODEL=gpt-5.1
QUERY_FORMAT_REASONING_EFFORT=low
QUERY_EXPANSION_ENABLED=true
QUERY_EXPANSION_MAX_ALTERNATIVES=2
QUERY_MULTI_ROUND_ENABLED=false
QUERY_REFLECTION_ENABLED=false
QUERY_CACHE_ENABLED=true
QUERY_CACHE_SIZE=2000

# Embedding（当前在线版仍建议走独立 embedding 服务）
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_BASE_URL=https://router.tumuer.me/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIMENSION=4096
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_CACHE_SIZE=5000
DISK_CACHE_ENABLED=false

# 文本 rerank
TEXT_RERANK_API_KEY=
TEXT_RERANK_BASE_URL=https://router.tumuer.me/v1
TEXT_RERANK_MODEL=Qwen/Qwen3-Reranker-8B
TEXT_RERANK_BACKEND=api
TEXT_RERANK_TIMEOUT=45

# 混合检索
VECTOR_METRIC=cosine
VECTOR_INDEX_TYPE=hnsw
HNSW_M=32
HNSW_EF_CONSTRUCTION=200
HNSW_EF_SEARCH=96
VECTOR_WEIGHT=0.85
KEYWORD_WEIGHT=0.15

# Elasticsearch（可选但推荐用于关键词/过滤检索）
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=photo_keywords
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Visual rerank
VISUAL_RERANK_ENABLED=true
VISUAL_RERANK_API_KEY=
VISUAL_RERANK_BASE_URL=
VISUAL_RERANK_MODEL=gpt-5.4
VISUAL_RERANK_REASONING_EFFORT=medium
VISUAL_RERANK_TIMEOUT=60
RERANK_IMAGE_MAX_SIZE=512
RERANK_IMAGE_QUALITY=75
RERANK_IMAGE_FORMAT=WEBP
RERANK_MAX_IMAGES=12

# 服务与索引
SERVER_HOST=127.0.0.1
SERVER_PORT=10001
TOP_K=12
DEFAULT_SEARCH_MODE=balanced
SEARCH_VALIDATE_FILE_EXISTS=false
BATCH_SIZE=8
MAX_RETRIES=3
TIMEOUT=45
INDEX_PATH=./data/photo_search.index
METADATA_PATH=./data/metadata.json
SECRET_KEY=dev-secret-key

# 图片编码
USE_BASE64=true
IMAGE_MAX_SIZE=1024
IMAGE_QUALITY=85
IMAGE_FORMAT=WEBP

# 说明：
# - 当前 /init_index 默认支持增量索引，日常新增图片后可直接再次调用
# - 只有切换 embedding 模型、修改 embedding_text / retrieval_text 生成逻辑或索引结构时，才建议全量重建
