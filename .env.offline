# Offline 版本
#
# 说明：
# - 所有模型都走本地 Ollama OpenAI 兼容接口。
# - base_url 使用 http://localhost:11434，代码会自动补成 /v1。
# - 本地 Ollama 场景允许 API key 为空。

PHOTO_DIR=C:/Users/86159/Desktop/test_photos

DATA_DIR=./data
RUNTIME_DATA_DIR=./data

# 通用 LLM（全部默认走本地 Ollama）
LLM_API_KEY=
LLM_BASE_URL=http://localhost:11434

# 兼容旧变量
SU8_API_KEY=${LLM_API_KEY}
SU8_BASE_URL=${LLM_BASE_URL}

# Vision / 结构化分析
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=qwen2.5vl:7b
VISION_REASONING_EFFORT=high
VISION_ENHANCED_REASONING_EFFORT=medium
VISION_BASE_MAX_TOKENS=900
VISION_ENHANCED_MAX_TOKENS=640
VISION_REPAIR_MAX_TOKENS=640
STRUCTURED_ANALYSIS_ENABLED=true
ENHANCED_ANALYSIS_ENABLED=true
TAG_MIN_CONFIDENCE=0.65
IDENTITY_TEXT_MIN_CONFIDENCE=0.70
IDENTITY_VISUAL_MIN_CONFIDENCE=0.92

# 时间解析：走本地 Ollama
TIME_PARSE_API_KEY=
TIME_PARSE_BASE_URL=
TIME_PARSE_MODEL=qwen2.5:7b-instruct
TIME_PARSE_REASONING_EFFORT=medium
TIME_PARSE_STRATEGY=local_first

# Query Formatter：走本地 Ollama
QUERY_FORMAT_ENABLED=true
QUERY_FORMAT_API_KEY=
QUERY_FORMAT_BASE_URL=
QUERY_FORMAT_MODEL=qwen2.5:7b-instruct
QUERY_FORMAT_REASONING_EFFORT=medium
QUERY_EXPANSION_ENABLED=true
QUERY_MULTI_ROUND_ENABLED=true
QUERY_REFLECTION_ENABLED=true
QUERY_MAX_EXPANSION_ROUNDS=2
QUERY_MAX_REFLECTION_ROUNDS=1
QUERY_EXPANSION_MAX_ALTERNATIVES=2
QUERY_DYNAMIC_THRESHOLD_FLOOR=0.08
QUERY_STRICT_FLOOR_MIN=0.32
QUERY_BROAD_FLOOR_MIN=0.20
QUERY_CACHE_ENABLED=true
QUERY_CACHE_SIZE=2000

# Embedding：走本地 Ollama
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_CACHE_SIZE=5000
DISK_CACHE_ENABLED=false

# 文本 rerank：走本地 Ollama
TEXT_RERANK_API_KEY=
TEXT_RERANK_BASE_URL=http://localhost:11434
TEXT_RERANK_MODEL=qwen3-reranker:8b
TEXT_RERANK_BACKEND=chat
TEXT_RERANK_TIMEOUT=90

# 混合检索
VECTOR_METRIC=cosine
VECTOR_INDEX_TYPE=hnsw
HNSW_M=48
HNSW_EF_CONSTRUCTION=320
HNSW_EF_SEARCH=192
VECTOR_WEIGHT=0.78
KEYWORD_WEIGHT=0.22

# Elasticsearch（可选）
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=photo_keywords
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Visual rerank：走本地 Ollama
VISUAL_RERANK_ENABLED=true
VISUAL_RERANK_API_KEY=
VISUAL_RERANK_BASE_URL=
VISUAL_RERANK_MODEL=qwen2.5vl:7b
VISUAL_RERANK_REASONING_EFFORT=medium
VISUAL_RERANK_TIMEOUT=150
RERANK_IMAGE_MAX_SIZE=640
RERANK_IMAGE_QUALITY=85
RERANK_IMAGE_FORMAT=WEBP
RERANK_MAX_IMAGES=16

# 服务与索引
SERVER_HOST=127.0.0.1
SERVER_PORT=10001
TOP_K=12
DEFAULT_SEARCH_MODE=high_recall
SEARCH_VALIDATE_FILE_EXISTS=true
BATCH_SIZE=4
MAX_RETRIES=3
TIMEOUT=120
INDEX_PATH=./data/photo_search.index
METADATA_PATH=./data/metadata.json
SECRET_KEY=dev-secret-key

# 图片编码
USE_BASE64=true
IMAGE_MAX_SIZE=1152
IMAGE_QUALITY=88
IMAGE_FORMAT=WEBP
